{
  "defaultMode": "acceptEdits",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/claude/biome-check.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/claude/install_pkgs.sh",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(node dist/cli.js measure --cwd example/jest-project --base main)",
      "Bash(node dist/cli.js diff --cwd example/jest-project --base main)",
      "Bash(pnpm build *)",
      "Bash(pnpm fmt *)",
      "Bash(pnpm test *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm install *)"
    ]
  },
  "statusLine": {
    "command": "jq -r '\"[\\(.model.display_name)] \\(.context_window.used_percentage // 0)% context\"'",
    "type": "command"
  }
}
